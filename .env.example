SECRET_KEY=change-me

# S3 (компатибильно с AWS S3 и S3-совместимыми хранилищами)
# Пример для Yandex Object Storage:
S3_BUCKET_NAME=cloud-app-zozin
S3_REGION=storage
S3_ENDPOINT_URL=https://storage.yandexcloud.net
# Для AWS S3 endpoint обычно не нужен; регион — например eu-central-1

# Учётные данные (либо используйте AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

S3_AVATAR_PREFIX=avatars
S3_PRESIGN_EXPIRES=3600

